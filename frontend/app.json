{
  "expo": {
    "name": "MOA",
    "slug": "moa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/blob_large.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/blob_large.png",
      "resizeMode": "contain",
      "backgroundColor": "#29B6E8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.moa.app"
    },
    "android": {
      "package": "com.moa.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA"
      ]
    },
    "scheme": "moa",
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      [
        "expo-audio",
        {
          "microphonePermission": "회의 녹음을 위해 마이크 접근 권한이 필요합니다."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "QR 코드 스캔으로 친구를 추가하기 위해 카메라 접근 권한이 필요합니다."
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "채팅에 사진을 보내기 위해 사진 라이브러리 접근 권한이 필요합니다.",
          "cameraPermission": "채팅에 사진을 촬영해 보내기 위해 카메라 접근 권한이 필요합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "newArchEnabled": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee20218a-d574-4997-b254-52ce828162ec"
      }
    }
  }
}
